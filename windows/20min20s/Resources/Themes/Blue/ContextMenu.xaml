<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    >
    <!--#region 右键菜单样式-->
    <Style  TargetType="{x:Type ContextMenu}">
        <Setter Property="Background" Value="#1E1E2E"/>
        <!--<Setter Property="BorderBrush" Value="{DynamicResource FluentBorderBrush}"/>-->
       
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContextMenu}">
                    <Grid>
                        <Border Margin="10" Background="#1E1E2E" CornerRadius="18">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0" Direction="0"  BlurRadius="26" Opacity=".38" />
                            </Border.Effect>
                        </Border>
                    <Border x:Name="Border"
                                Background="#1E1E2E"
                                BorderBrush="#313244"
                                BorderThickness="1"
                                Padding="0"
                                Margin="6"
                                CornerRadius="18"
                                >
                        <!--<Border.Effect>
                            <DropShadowEffect ShadowDepth="0" Direction="0"  BlurRadius="0" Opacity="0" />
                        </Border.Effect>-->
                        <ScrollViewer Focusable="false" Padding="0">

                            <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>

                        </ScrollViewer>
                    </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
