<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:Project1.UI.Controls;assembly=Project1.UI"
                    xmlns:converter="clr-namespace:Project1.UI.Controls.Converters;assembly=Project1.UI"
                    >
    <converter:StringConverter x:Key="StringConverter"/>
    <Style TargetType="{x:Type controls:CompareView}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#A6ADC8" />
        <Setter Property="UPColor" Value="#F38BA8" />
        <Setter Property="DownColor" Value="#A6E3A1" />
        <Setter Property="NoChangeColor" Value="#A6ADC8" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="SnapsToDevicePixels" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:CompareView}">
                    <Grid>
                        <Popup
                            x:Name="Popup"
                            Placement="Top"
                            PlacementTarget="{Binding ElementName=Border}"
                            AllowsTransparency="True"
                            HorizontalOffset="-10"
                            >
                            <Border
                                x:Name="PopupBorder"
                                Background="#1E1E2E"
                                BorderBrush="#313244"
                                BorderThickness="1"
                                Padding="12,10"
                                Margin="15"
                                CornerRadius="14"
                                >
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="16" Opacity="0.28" ShadowDepth="0" Color="#05070B"/>
                                </Border.Effect>
                                <Grid>
                                    <TextBlock x:Name="PopupText"
                                               Foreground="#CDD6F4"
                                               TextWrapping="Wrap"
                                               MaxWidth="220"/>
                                    <Path 
                      Width="15"
                      Height="15"
                      SnapsToDevicePixels="False"
                      Data="M 0 0 L 7.5 7.5 L 15 0" Fill="#1E1E2E"
                                        Stroke="#313244"
                                        StrokeThickness="1"
                                        VerticalAlignment="Bottom"
                                        HorizontalAlignment="Left"
                                        Margin="-5,0,0,-25"
                                        />
                                </Grid>

                            </Border>
                        </Popup>
                        <Border
                            x:Name="Border"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Background="{TemplateBinding Background}"
                        Padding="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{TemplateBinding DataB,Converter={StaticResource StringConverter}}"
                                       FontSize="26" FontWeight="Bold" Margin="0,0,10,0" Foreground="#CDD6F4"/>
                                <TextBlock x:Name="UPIcon" FontFamily="Segoe MDL2 Assets" Text="&#xE70E;" Margin="0,4,0,0" FontSize="11" Visibility="Collapsed" Foreground="{TemplateBinding UPColor}"/>
                                <TextBlock x:Name="DownIcon" FontFamily="Segoe MDL2 Assets" Text="&#xE70D;" Margin="0,4,0,0" FontSize="11" Visibility="Collapsed" Foreground="{TemplateBinding DownColor}"/>
                                <TextBlock x:Name="NoCIcon" Text="-" Margin="0,1,0,0" FontSize="16" Visibility="Collapsed" Foreground="{TemplateBinding NoChangeColor}" FontWeight="SemiBold"/>
                                <Border Margin="8,0,0,0"
                                        Padding="8,4"
                                        CornerRadius="8"
                                        Background="#313244">
                                    <TextBlock x:Name="DiffValue" FontSize="13" Foreground="{TemplateBinding Foreground}" FontWeight="SemiBold">
                                        <Run Text="{TemplateBinding DiffValue,Converter={StaticResource StringConverter}}"/><Run Text="%"/>
                                    </TextBlock>
                                </Border>

                            </StackPanel>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Popup" Property="IsOpen" Value="true"/>
                            <Setter TargetName="DiffValue" Property="Foreground" Value="#CDD6F4"/>
                        </MultiTrigger>
                        <Trigger Property="DiffValueStatus" Value="Up">
                            <Setter TargetName="UPIcon" Property="Visibility" Value="Visible" />


                        </Trigger>
                        <Trigger Property="DiffValueStatus" Value="Down">
                            <Setter TargetName="DownIcon" Property="Visibility" Value="Visible" />

                        </Trigger>
                        <Trigger Property="DiffValueStatus" Value="NoChange">
                            <Setter TargetName="NoCIcon" Property="Visibility" Value="Visible" />

                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

    </Style>


</ResourceDictionary>
