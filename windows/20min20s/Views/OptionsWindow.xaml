                                <TextBlock Text="{DynamicResource Lang_Specifythetime}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <ui:TimeBox Hour="{Binding Model.Data.Style.AutoDarkStartH,Mode=TwoWay}" Minutes="{Binding Model.Data.Style.AutoDarkStartM,Mode=TwoWay}"/>
                                    <TextBlock Text=" " VerticalAlignment="Center" Margin="5,0"/>
                                    <ui:TimeBox Hour="{Binding Model.Data.Style.AutoDarkEndH,Mode=TwoWay}" Minutes="{Binding Model.Data.Style.AutoDarkEndM,Mode=TwoWay}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <ui:Toggle Text="{DynamicResource Lang_Showbuttonsinfullscreennotification}" IsChecked="{Binding Model.IsTipAsk,Mode=TwoWay}" Cursor="Hand" Margin="0,20,0,0" />
