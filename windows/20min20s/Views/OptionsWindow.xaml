<ui:Project1UIWindow x:Class="ProjectEye.Views.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjectEye.Views"
        xmlns:ui="clr-namespace:Project1.UI.Controls;assembly=Project1.UI"
        xmlns:cmd="clr-namespace:Project1.UI.Controls.Commands;assembly=Project1.UI"
        xmlns:converter="clr-namespace:Project1.UI.Controls.Converters;assembly=Project1.UI"
        mc:Ignorable="d"
        Title="{DynamicResource Lang_Settings}" Height="760" Width="1040"
        MinWidth="900" MinHeight="680"
        MaxWidth="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Width}"
        MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height}"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize" Icon="/20min20s;component/Resources/sunglasses.ico">
    <ui:Project1UIWindow.Resources>
        <converter:Project1UIIconToUnicodeConverter x:Key="OptionsIconToUnicodeConverter"/>
        <SolidColorBrush x:Key="OptionsPageBackgroundBrush" Color="#11111B"/>
        <SolidColorBrush x:Key="OptionsShellBackgroundBrush" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="OptionsMutedBrush" Color="#A6ADC8"/>
        <SolidColorBrush x:Key="OptionsNavBackgroundBrush" Color="#181825"/>
        <SolidColorBrush x:Key="OptionsPanelBackgroundBrush" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="OptionsAccentBrush" Color="#CBA6F7"/>
        <SolidColorBrush x:Key="OptionsAccentHoverBrush" Color="#D8BBF8"/>
        <SolidColorBrush x:Key="OptionsTrackBrush" Color="#313244"/>
        <SolidColorBrush x:Key="OptionsTrackInactiveBrush" Color="#313244"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8ECF8"/>
        </Style>
        <Style TargetType="Hyperlink">
            <Setter Property="Foreground" Value="#AEBEFF"/>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="Padding" Value="12,0,34,0"/>
            <Setter Property="Background" Value="#181825"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#181825"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#181825"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#313244"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#CDD6F4"/>
            </Style.Resources>
        </Style>
        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
            <Setter Property="Background" Value="#181825"/>
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#313244"/>
                    <Setter Property="Foreground" Value="#CDD6F4"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#313244"/>
                    <Setter Property="Foreground" Value="#CBA6F7"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#6C7086"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FlatSliderStyle" TargetType="Slider">
            <Setter Property="Margin" Value="0,10,0,10"/>
            <Setter Property="MinHeight" Value="54"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="ToolTipService.IsEnabled" Value="False"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{TemplateBinding Tag}"
                                           FontSize="14"
                                           FontWeight="Medium"
                                           Foreground="#CDD6F4"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="1"
                                        Background="#313244"
                                        BorderThickness="0"
                                        CornerRadius="8"
                                        Padding="8,4"
                                        Margin="10,0,0,0">
                                    <TextBlock FontSize="13"
                                               Foreground="#CDD6F4"
                                               FontWeight="SemiBold">
                                        <Run Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Value, StringFormat=F0}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ToolTip}"/>
                                    </TextBlock>
                                </Border>
                            </Grid>
                            <Grid Grid.Row="1" Height="20" VerticalAlignment="Center">
                                <Border Height="4"
                                        CornerRadius="999"
                                        Background="{StaticResource OptionsTrackBrush}"
                                        VerticalAlignment="Center"/>
                                <Track x:Name="PART_Track"
                                       Minimum="{TemplateBinding Minimum}"
                                       Maximum="{TemplateBinding Maximum}"
                                       Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Value, Mode=TwoWay}"
                                       ViewportSize="0"
                                       IsDirectionReversed="{TemplateBinding IsDirectionReversed}">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="Slider.DecreaseLarge"
                                                      IsTabStop="False"
                                                      Focusable="False"
                                                      FocusVisualStyle="{x:Null}"
                                                      Template="{DynamicResource SliderDecreaseButtonTemplate}"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Width="14" Height="14" Focusable="False" FocusVisualStyle="{x:Null}" Background="Transparent" BorderThickness="0">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Width="14"
                                                            Height="14"
                                                            CornerRadius="7"
                                                            Background="{StaticResource OptionsAccentBrush}"/>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="Slider.IncreaseLarge"
                                                      IsTabStop="False"
                                                      Focusable="False"
                                                      FocusVisualStyle="{x:Null}"
                                                      Template="{DynamicResource SliderIncreaseButtonTemplate}"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <ControlTemplate x:Key="SliderDecreaseButtonTemplate" TargetType="RepeatButton">
            <Border Height="4"
                    Background="{StaticResource OptionsAccentBrush}"
                    CornerRadius="999"/>
        </ControlTemplate>
        <ControlTemplate x:Key="SliderIncreaseButtonTemplate" TargetType="RepeatButton">
            <Border Height="4"
                    Background="Transparent"
                    CornerRadius="999"/>
        </ControlTemplate>
        <Style TargetType="{x:Type ui:Project1UIInput}">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="KeyboardNavigation.TabNavigation" Value="None" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="SelectionBrush" Value="{DynamicResource InputFocusedBorderBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Width" Value="120" />
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="IconSize" Value="12" />
            <Setter Property="BorderThickness" Value="{DynamicResource InputThickness}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="#181825"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="Padding" Value="14,0,14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ui:Project1UIInput}">
                        <Border Name="Border"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        x:Name="Icon"
                                        Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}">
                                    <TextBlock x:Name="IconTextBlock"
                                               Text="{TemplateBinding Icon,Converter={StaticResource OptionsIconToUnicodeConverter}}"
                                               Foreground="{DynamicResource InputIconForeground}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="{TemplateBinding IconSize}" />
                                </Border>
                                <Button x:Name="ClearButton"
                                        ToolTip="{DynamicResource Lang_Emptytheinput}"
                                        Visibility="Collapsed"
                                        Grid.Column="3"
                                        Focusable="False"
                                        Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}"
                                        Style="{DynamicResource WindowSystemButton}"
                                        Content="&#xE894;"
                                        Command="{x:Static cmd:Project1UIInputCommands.ClearTextCommand}"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Grid.Column="1"
                                              Panel.ZIndex="2"
                                              Margin="5,0" />
                                <TextBlock x:Name="Placeholder"
                                           Panel.ZIndex="1"
                                           FontSize="{TemplateBinding FontSize}"
                                           VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                           HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                           Grid.Column="1"
                                           Text="{TemplateBinding Placeholder}"
                                           Visibility="Collapsed"
                                           Foreground="{DynamicResource InputIconForeground}"
                                           Margin="5,0" />
                                <Button x:Name="FolderButton"
                                        ToolTip="{DynamicResource Lang_Selectfolder}"
                                        Visibility="Collapsed"
                                        Grid.Column="4"
                                        Command="{x:Static cmd:Project1UIInputCommands.CommonOpenFileDialog}"
                                        Focusable="False"
                                        Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}"
                                        Style="{DynamicResource WindowSystemButton}">
                                    <TextBlock Text="&#xE710;" />
                                </Button>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsReadOnly" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource InputEnterBorderBrush}"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsFocused" Value="True" />
                                    <Condition Property="IsReadOnly" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource InputFocusedBorderBrush}"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsFocused" Value="True" />
                                    <Condition Property="IsReadOnly" Value="False" />
                                    <Condition Property="IconAlignment" Value="Left" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ClearButton" Property="Visibility" Value="Visible"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsFocused" Value="True" />
                                    <Condition Property="IsReadOnly" Value="False" />
                                    <Condition Property="IconAlignment" Value="Right" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ClearButton" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                            </MultiTrigger>
                            <Trigger Property="Type" Value="FileSelect">
                                <Setter TargetName="FolderButton" Property="ToolTip" Value="{DynamicResource Lang_Selectfile}" />
                                <Setter TargetName="FolderButton" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="Type" Value="FolderSelect">
                                <Setter TargetName="FolderButton" Property="ToolTip" Value="{DynamicResource Lang_Selectfolder}" />
                                <Setter TargetName="FolderButton" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IconAlignment" Value="Left">
                                <Setter TargetName="Icon" Property="Grid.Column" Value="0" />
                            </Trigger>
                            <Trigger Property="IconAlignment" Value="Right">
                                <Setter TargetName="Icon" Property="Grid.Column" Value="2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#bbbbbe" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="#bbbbbe" />
                            </Trigger>
                            <DataTrigger Binding="{Binding Path=Text, RelativeSource={RelativeSource Mode=Self}}" Value="">
                                <Setter TargetName="ClearButton" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="Icon" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource DisableBrush}" />
                                <Setter Property="Foreground" TargetName="Placeholder" Value="{DynamicResource DisableBrush}" />
                                <Setter Property="Foreground" TargetName="IconTextBlock" Value="{DynamicResource DisableBrush}" />
                                <Setter Property="Foreground" TargetName="FolderButton" Value="{DynamicResource DisableBrush}" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource DisableBrush}" />
                            </Trigger>
                            <Trigger Property="Icon" Value="Null">
                                <Setter TargetName="Icon" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type ui:Project1UIKeyboardInput}">
            <Setter Property="Background" Value="#181825" />
            <Setter Property="SnapsToDevicePixels" Value="False" />
            <Setter Property="Width" Value="120" />
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="BorderThickness" Value="{DynamicResource InputThickness}"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="InputMethod.IsInputMethodEnabled" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ui:Project1UIKeyboardInput}">
                        <Border x:Name="Border"
                                CornerRadius="12"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid>
                                    <TextBlock x:Name="PTEXT"
                                               Text="{TemplateBinding Placeholder}"
                                               HorizontalAlignment="Center"
                                               Visibility="Collapsed"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource InputIconForeground}"/>
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{TemplateBinding Foreground}"
                                               Text="{TemplateBinding KeyText}"/>
                                </Grid>
                                <Button x:Name="ClearButton"
                                        ToolTip="清除按键"
                                        Visibility="Visible"
                                        Grid.Column="1"
                                        Focusable="False"
                                        Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}"
                                        Style="{DynamicResource WindowSystemButton}"
                                        Content="&#xE894;"
                                        Command="{x:Static cmd:Project1UIInputCommands.ClearTextCommand}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding Path=KeyText, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                <Setter TargetName="PTEXT" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ClearButton" Property="Visibility" Value="Hidden" />
                            </DataTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource InputEnterBorderBrush}"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsFocused" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource InputFocusedBorderBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListView">
            <Setter Property="Background" Value="#171D2A"/>
            <Setter Property="BorderBrush" Value="#2C3550"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#E8ECF8"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E8ECF8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="8,6"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#20283B"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#28324A"/>
                    <Setter Property="Foreground" Value="#F7F9FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#1B2231"/>
            <Setter Property="Foreground" Value="#C7D0EA"/>
            <Setter Property="BorderBrush" Value="#2C3550"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TabControl" BasedOn="{StaticResource {x:Type TabControl}}">
            <Setter Property="TabStripPlacement" Value="Left"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}">
            <Setter Property="MinWidth" Value="176"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="18,12"/>
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Foreground" Value="#AAB2C9"/>
        </Style>
        <Style TargetType="{x:Type ui:Toggle}">
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ui:Toggle}">
                        <Grid Margin="{TemplateBinding Margin}"
                              SnapsToDevicePixels="True"
                              UseLayoutRounding="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       x:Name="ToggleLabel"
                                       Text="{TemplateBinding Text}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,16,0"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       TextWrapping="Wrap"
                                       TextOptions.TextFormattingMode="Display"
                                       Foreground="#CDD6F4"/>
                            <Border x:Name="ToggleTrack"
                                    Grid.Column="1"
                                    Width="44"
                                    Height="24"
                                    Margin="0,4,0,4"
                                    Background="#313244"
                                    BorderBrush="#45475A"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    VerticalAlignment="Center">
                                <Border x:Name="ToggleThumb"
                                        Width="16"
                                        Height="16"
                                        Margin="3,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        CornerRadius="8"
                                        Background="#6C7086">
                                    <Border.RenderTransform>
                                        <TranslateTransform X="0"/>
                                    </Border.RenderTransform>
                                </Border>
                            </Border>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="On">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="ToggleTrack"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#CBA6F7"
                                                            Duration="0:0:0.18"/>
                                            <ColorAnimation Storyboard.TargetName="ToggleTrack"
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#D8BBF8"
                                                            Duration="0:0:0.18"/>
                                            <ColorAnimation Storyboard.TargetName="ToggleThumb"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#1E1E2E"
                                                            Duration="0:0:0.18"/>
                                            <DoubleAnimation Storyboard.TargetName="ToggleThumb"
                                                             Storyboard.TargetProperty="(Border.RenderTransform).(TranslateTransform.X)"
                                                             To="20"
                                                             Duration="0:0:0.18"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Off">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="ToggleTrack"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#313244"
                                                            Duration="0:0:0.18"/>
                                            <ColorAnimation Storyboard.TargetName="ToggleTrack"
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#45475A"
                                                            Duration="0:0:0.18"/>
                                            <ColorAnimation Storyboard.TargetName="ToggleThumb"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#6C7086"
                                                            Duration="0:0:0.18"/>
                                            <DoubleAnimation Storyboard.TargetName="ToggleThumb"
                                                             Storyboard.TargetProperty="(Border.RenderTransform).(TranslateTransform.X)"
                                                             To="0"
                                                             Duration="0:0:0.18"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="EnabledStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="ToggleTrack"
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#585B70"
                                                            Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ToggleTrack"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.45"
                                                             Duration="0:0:0"/>
                                            <DoubleAnimation Storyboard.TargetName="ToggleThumb"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.65"
                                                             Duration="0:0:0"/>
                                            <DoubleAnimation Storyboard.TargetName="ToggleLabel"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.55"
                                                             Duration="0:0:0"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SidebarTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="HeaderHost"
                                              ContentSource="Header"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontSize="14"
                                              TextElement.FontWeight="SemiBold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#313244"/>
                                <Setter Property="Foreground" Value="#CDD6F4"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#313244"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#585B70"/>
                                <Setter Property="Foreground" Value="#CBA6F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SidebarTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
