                        <ui:Toggle Text="{DynamicResource Lang_Enableanimation}" IsChecked="{Binding Model.Data.Style.IsAnimation,Mode=TwoWay}" Cursor="Hand" Margin="0,20,0,0" />


                        <ui:Toggle Text="{DynamicResource Lang_Earlypopupforbreaktime}" IsChecked="{Binding Model.IsPreAlert}" Cursor="Hand" Margin="0,20,0,0" />
                        <Grid Margin="0,10,0,0" Visibility="{Binding Model.PreAlertConfigVisibility}">
                            <!--预提醒配置-->
                            <StackPanel Margin="30,0,0,0">
                                <!--预提醒提示音-->
                                <CheckBox Content="{DynamicResource Lang_Popupsound}" IsChecked="{Binding Model.Data.Style.IsPreAlertSound}" Cursor="Hand" Margin="0,0,0,0"/>
                                <!--预提醒提前时间-->
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                   Margin="0,0,10,0" VerticalAlignment="Top" Text="{DynamicResource Lang_Popupleadtime}"></TextBlock>

                                    <Grid Grid.Column="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider Grid.Column="0" Style="{StaticResource FlatSliderStyle}" Maximum="60" Minimum="3" SmallChange="1" Value="{Binding Model.Data.Style.PreAlertTime}" ToolTip="{DynamicResource Lang_Seconds}"/>
                                        <!--<TextBlock Grid.Column="2" Margin="10,0,0,0">
                                            <Run Text="{Binding Model.Data.Style.PreAlertTime}"/>
                                            <Run Text="{DynamicResource Lang_Seconds}"/>
                                        </TextBlock>-->
                                    </Grid>
                                </Grid>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                   Margin="0,0,10,0" VerticalAlignment="Center" Text="{DynamicResource Lang_Defaultactionafterthepopup}"></TextBlock>
                                    <ComboBox 
                             Grid.Column="1" 
                                  ItemsSource="{Binding Model.PreAlertActions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedItem="{Binding Model.Data.Style.PreAlertAction}"
                            SelectedValue="{Binding Model.Data.Style.PreAlertAction.Value}"
                            SelectedValuePath="Value"
                                 />


                                </Grid>
                                <!--预提醒的弹窗内容配置-->
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                   Margin="0,0,10,0" VerticalAlignment="Center" Text="{DynamicResource Lang_Icon}"></TextBlock>

                                    <ui:Project1UIInput Grid.Column="1"  TextWrapping="NoWrap" Text="{Binding Model.Data.Style.PreAlertIcon}" Width="auto" Placeholder="{DynamicResource Lang_Leaveblankfordefault}"
                                            Type="FileSelect"
                                            ExtNames=".jpg|*.jpg|.png|*.png"/>
                                </Grid>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                   Margin="0,0,10,0" VerticalAlignment="Center" Text="{DynamicResource Lang_Title}"></TextBlock>

                                    <ui:Project1UIInput
                                Text="{Binding Model.Data.Style.PreAlertTitle}"
                                Width="auto"
                                Placeholder=""
                                Type="Text"
                                VerticalContentAlignment="Center"
                                            Grid.Column="1"/>

                                </Grid>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                   Margin="0,0,10,0" VerticalAlignment="Center" Text="{DynamicResource Lang_Subtitle}"></TextBlock>

                                    <ui:Project1UIInput
                                Text="{Binding Model.Data.Style.PreAlertSubtitle}"
                                Width="auto"
                                Placeholder=""
                                Type="Text"
                                VerticalContentAlignment="Center"
                                            Grid.Column="1"/>

                                </Grid>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                   Margin="0,0,10,0" VerticalAlignment="Top" Text="{DynamicResource Lang_Content}"></TextBlock>
                                    <StackPanel Grid.Column="1">
                                        <ui:Project1UIInput
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                Text="{Binding Model.Data.Style.PreAlertMessage}"
                                Width="auto"
                                Type="Text"
                                Height="40"
                                VerticalContentAlignment="Top"/>
                                        <TextBlock Text="{DynamicResource Lang_Variablesdescription}" Foreground="#FF838383" TextWrapping="Wrap"/>
                                    </StackPanel>


                                </Grid>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{DynamicResource Lang_StatisticsWindow}" FontSize="14" FontWeight="Bold" Margin="0,20,0,0"/>
                        <TextBlock Text="{DynamicResource Lang_DataWindowWorkTimeImagePath}"  Margin="0,15,0,0"/>
                        <ui:Project1UIInput  TextWrapping="NoWrap" Text="{Binding Model.Data.Style.DataWindowWorkTimeImagePath}" Width="auto" Placeholder="{DynamicResource Lang_Leaveblankfordefault}"
                                            Type="FileSelect"
                                                Icon="Photo"
                                            ExtNames=".jpg|*.jpg|.png|*.png"
                                             Margin="0,10,0,0"/>
                        <TextBlock Text="{DynamicResource Lang_DataWindowRestTimeImagePath}"  Margin="0,15,0,0"/>
                        <ui:Project1UIInput  TextWrapping="NoWrap" Text="{Binding Model.Data.Style.DataWindowRestTimeImagePath}" Width="auto" Placeholder="{DynamicResource Lang_Leaveblankfordefault}"
                                            Type="FileSelect"
                                                Icon="Photo"
                                            ExtNames=".jpg|*.jpg|.png|*.png"
                                             Margin="0,10,0,0"/>
                        <TextBlock Text="{DynamicResource Lang_DataWindowSkipImagePath}"  Margin="0,15,0,0"/>
                        <ui:Project1UIInput  TextWrapping="NoWrap" Text="{Binding Model.Data.Style.DataWindowSkipImagePath}" Width="auto" Placeholder="{DynamicResource Lang_Leaveblankfordefault}"
                                            Type="FileSelect"
                                                Icon="Photo"
                                            ExtNames=".jpg|*.jpg|.png|*.png"
                                             Margin="0,10,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <TextBlock>
                        <Run FontFamily="Segoe MDL2 Assets" Text="&#xE765;"/>
                        <Run Text="  "/>
                        <Run Text="{DynamicResource Lang_Hotkeys}"/>
                    </TextBlock>
                </TabItem.Header>
                <StackPanel Margin="10">
                    <TextBlock Text="{DynamicResource Lang_Hotkeys}" Style="{StaticResource TabSectionTitleStyle}"/>
                    <TextBlock Text="为开始休息和跳过休息设置全局快捷键。"
                               Style="{StaticResource TabSectionHintStyle}"/>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                        </Grid.RowDefinitions>
                        <!--进入休息-->
                        <TextBlock Grid.Column="0"
                                   Margin="0,0,10,0" VerticalAlignment="Center" Text="{DynamicResource Lang_Startthebreak}"></TextBlock>
                        <ui:Project1UIKeyboardInput Grid.Column="1" Width="220" KeyText="{Binding Model.Data.KeyboardShortcuts.Reset,Mode=TwoWay}" Placeholder="{DynamicResource Lang_Pleasepressakey}" HorizontalAlignment="Left"/>
                        <!--跳过休息-->
                        <TextBlock 
                            Grid.Row="1"
                            Grid.Column="0"
                                   Margin="0,0,10,0" VerticalAlignment="Center" Text="{DynamicResource Lang_Skipthebreak}"></TextBlock>
                        <ui:Project1UIKeyboardInput 
                            Grid.Row="1"
                            Grid.Column="1" Width="220" KeyText="{Binding Model.Data.KeyboardShortcuts.NoReset,Mode=TwoWay}" Placeholder="{DynamicResource Lang_Pleasepressakey}" HorizontalAlignment="Left"/>
                    </Grid>

                </StackPanel>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <TextBlock>
                        <Run FontFamily="Segoe MDL2 Assets" Text="&#xE7C3;"/>
                        <Run Text="  "/>
                        <Run Text="{DynamicResource Lang_Behaviors}"/>
                    </TextBlock>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="10">
                        <TextBlock Text="{DynamicResource Lang_Behaviors}" Style="{StaticResource TabSectionTitleStyle}"/>
                        <TextBlock Text="控制全屏不打扰、空闲暂停和跳过限制等运行时行为。"
                                   Style="{StaticResource TabSectionHintStyle}"/>
                        <TextBlock Text="运行策略" Style="{StaticResource SectionSubTitleStyle}"/>
                        <ui:Toggle Text="{DynamicResource Lang_HandleTimeoutAutoRest}" IsChecked="{Binding Model.Data.Behavior.IsHandleTimeoutRest}" Cursor="Hand" Margin="0,20,0,0" />
                        <ui:Toggle Text="{DynamicResource Lang_Breakscannotbeskipped}"  IsChecked="{Binding Model.Data.Behavior.IsDisabledSkip}" Cursor="Hand" Margin="0,10,0,0"/>
                        <Slider Margin="0,20,0,0"
                                Style="{StaticResource FlatSliderStyle}"
                                Tag="{DynamicResource Lang_IdlePauseSeconds}"
                                Maximum="300"
                                Minimum="5"
                                SmallChange="5"
                                Value="{Binding Model.Data.Behavior.IdlePauseSeconds}"
                                ToolTip="{DynamicResource Lang_Seconds}"/>
                        <ui:Toggle Text="{DynamicResource Lang_Donotdisturbwhenrunningfullscreenapplications}"  IsChecked="{Binding Model.Data.Behavior.IsFullScreenBreak}" Cursor="Hand" Margin="0,20,0,0"/>
                        <Slider Margin="0,20,0,0"
                                Style="{StaticResource FlatSliderStyle}"
                                Tag="{DynamicResource Lang_DeferredBreakReminderDelaySeconds}"
                                Maximum="15"
                                Minimum="0"
                                SmallChange="1"
                                Value="{Binding Model.Data.Behavior.DeferredBreakReminderDelaySeconds}"
                                ToolTip="{DynamicResource Lang_Seconds}"/>
                        <ui:Toggle Text="{DynamicResource Lang_Donotdisturbwhenfollowingprocessesarerunning}" IsChecked="{Binding Model.IsBreakProgressList,Mode=TwoWay}" Cursor="Hand" Margin="0,20,0,0" />
                        <TextBlock Text="进程白名单" Style="{StaticResource SectionSubTitleStyle}"/>
                        <Grid Margin="0,10,0,0" Visibility="{Binding Model.BreakProgressListVisibility}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="150"/>
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <ui:Project1UIInput
                                    Name="breakProcessTextbox"
                                Width="auto"
                                Placeholder="{DynamicResource Lang_Processname}"
                                Type="Text"
                                    MinHeight="23"
                                VerticalContentAlignment="Center"/>
                                <ui:Project1UIButton 
                                Grid.Column="1"
            Command="{Binding addBreackProcessCommand}"
                                    CommandParameter="{Binding ElementName=breakProcessTextbox,Path=Text}"
            Content="{DynamicResource Lang_Add}"
            MinHeight="23"
            MinWidth="85"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right"
                Style="{DynamicResource basic}"/>
                                <ui:Project1UIButton
                                Grid.Column="2"
                                Margin="10,0,0,0"
                                Command="{Binding removeBreackProcessCommand}"
                                Content="{DynamicResource Lang_Remove}"
                                MinHeight="23"
                                MinWidth="85"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right"
                Style="{StaticResource InlineGhostButton}"/>
                            </Grid>
                            <ListView
            Grid.Row="1"
            ItemsSource="{Binding Model.Data.Behavior.BreakProgressList,Mode=TwoWay}"
            SelectionMode="Single"
                                SelectedItem="{Binding Model.SelectedItem}"
                                Name="breakProcessListView"
                                 Margin="0,10,0,0"
           >

                                <ListView.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="{DynamicResource Lang_Remove}"  Command="{Binding removeBreackProcessCommand}"/>
                                    </ContextMenu>
                                </ListView.ContextMenu>

                                <ListView.View>
                                    <GridView>
                                        <GridView.Columns>
                                            <GridViewColumn Width="{Binding ElementName=breakProcessListView,Path=ActualWidth}">
                                                <GridViewColumn.Header>
                                                    <TextBlock Text="{DynamicResource Lang_Processname}" HorizontalAlignment="Left" Width="{Binding ElementName=breakProcessListView,Path=ActualWidth}"/>
                                                </GridViewColumn.Header>
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Grid Width="auto">
                                                            <TextBlock Text="{Binding}" HorizontalAlignment="Left" Width="{Binding ElementName=breakProcessListView,Path=ActualWidth}"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>

                                        </GridView.Columns>

                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                        
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <TextBlock>
                        <Run FontFamily="Segoe MDL2 Assets" Text="&#xE946;"/>
                        <Run Text="  "/>
                        <Run Text="{DynamicResource Lang_About}"/>
                    </TextBlock>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="10">
                        <TextBlock Text="{DynamicResource Lang_About}" Style="{StaticResource TabSectionTitleStyle}"/>
                        <TextBlock Text="查看版本、文档、贡献者和项目仓库入口。"
                                   Style="{StaticResource TabSectionHintStyle}"/>
                        <TextBlock Text="项目信息" Style="{StaticResource SectionSubTitleStyle}"/>
                        <Image RenderTransformOrigin="0.5,0.5" Source="/20min20s;component/Resources/sunglasses.ico" Height="30" HorizontalAlignment="Left"  Margin="0,10,0,0">
                            <Image.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Image.RenderTransform>
                            <Image.Triggers>
                                <EventTrigger RoutedEvent="MouseDown">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)">
                                                <EasingDoubleKeyFrame KeyTime="0:0:.1" Value="1.5"  />
                                                <EasingDoubleKeyFrame KeyTime="0:0:.4" Value="1"  />

                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)">
                                              
                                                <EasingDoubleKeyFrame KeyTime="0:0:.1" Value="1.5" />
                                                <EasingDoubleKeyFrame KeyTime="0:0:.4" Value="1"  />
                                                
                                            </DoubleAnimationUsingKeyFrames>
                                            <!--<DoubleAnimation  Duration="0:0:.3" To="1.5" Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)" AutoReverse="True"/>
                                            <DoubleAnimation Duration="0:0:.3" To="1.5" Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)" AutoReverse="True"/>-->
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Image.Triggers>
                        </Image>
                        <TextBlock TextWrapping="Wrap" Text="20min20s"
                               Margin="0,10,0,0" FontWeight="Bold"/>
                        <TextBlock TextWrapping="Wrap" Text="{DynamicResource Lang_Aprogramwhichprotectsyoureyesbehindthescenes}"
                               Margin="0,10,0,0" Opacity=".5"/>
                        <TextBlock TextWrapping="Wrap"
                               Margin="0,10,0,0"><Run Text="{DynamicResource Lang_Version}"/> <Hyperlink Command="{Binding openurlCommand}"
                                      CommandParameter="{Binding Model.VersionLink}" ><Run Text="{Binding Model.Version}"/></Hyperlink> <Hyperlink Command="{Binding updateCommand}"><Run Text="{DynamicResource Lang_Checkforupdates}"/></Hyperlink></TextBlock>

                        <!--<Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="40"/>
                            </Grid.RowDefinitions>
                            <TextBlock 
                                Grid.Row="0"
                                Grid.Column="0" 
                                Text="{DynamicResource Lang_Help}"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                TextWrapping="WrapWithOverflow"
                                VerticalAlignment="Center"
                                Foreground="#4f6bed"
                                Cursor="Hand"
                                Text="https://littlepanda.gitbook.io/project-eye"
                                />
                        </Grid>-->
                        <TextBlock TextWrapping="Wrap" Margin="0,10,0,0">
                        <Hyperlink Command="{Binding openWindowCommand}" CommandParameter="ContributorsWindow">
                            <Run Text="{DynamicResource Lang_Contributors}"/>
                        </Hyperlink>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,10,0,0">
                        <Run Text="{DynamicResource Lang_Help}"/> <Hyperlink  Command="{Binding openurlCommand}"
                                      CommandParameter="https://github.com/tiyadegure/20mins20s#readme">项目文档</Hyperlink>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,10,0,0">
                         <Run Text="{DynamicResource Lang_Source}"/> <Hyperlink Command="{Binding openurlCommand}"
                                      CommandParameter="https://github.com/tiyadegure/20mins20s">20min20s 仓库</Hyperlink>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,10,0,0">
                         <Run Text="{DynamicResource Lang_Feedback}"/> <Hyperlink  Command="{Binding openurlCommand}"
                                      CommandParameter="https://github.com/tiyadegure/20mins20s/issues">20min20s Issues</Hyperlink>
                        </TextBlock>
                        <!--<TextBlock TextWrapping="Wrap" Margin="0,10,0,0">
                         <Run Text="{DynamicResource Lang_Developers}"/> <Hyperlink  Command="{Binding openurlCommand}"
                                      CommandParameter="http://thelittlepandaisbehind.com">http://thelittlepandaisbehind.com</Hyperlink>
                        </TextBlock>-->
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
        <Border Grid.Row="1"
                Background="#181825"
                BorderThickness="0"
                CornerRadius="16"
                Padding="16,14">
        <StackPanel Orientation="Horizontal"
                     HorizontalAlignment="Right"
            VerticalAlignment="Bottom">
            <ui:Project1UIButton 
            Command="{Binding inkCommand}"
            Content="{DynamicResource Lang_Createashortcutondesktop}"
                Style="{StaticResource FooterSecondaryButton}"
                Background="#313244"
                Foreground="#CDD6F4"
                BorderBrush="#45475A"/>
          
            <ui:Project1UIButton 
            Command="{Binding applyCommand}"
            Content="{DynamicResource Lang_Apply}"
                Margin="10,0,0,0"
                Style="{StaticResource FooterPrimaryButton}"
                Icon="Null"
                Background="#CBA6F7"
                Foreground="#11111B"
                BorderBrush="#CBA6F7"/>
        </StackPanel>
        </Border>
            </Grid>
        </Border>
    </Grid>
</ui:Project1UIWindow>
