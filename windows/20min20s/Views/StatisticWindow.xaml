<ui:Project1UIWindow x:Class="ProjectEye.Views.StatisticWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjectEye.Views"
        xmlns:ui="clr-namespace:Project1.UI.Controls;assembly=Project1.UI"
        xmlns:chart="clr-namespace:Project1.UI.Controls.ChartControl;assembly=Project1.UI"
        mc:Ignorable="d"
                     xmlns:date="clr-namespace:Project1.UI.Controls.DatePicker;assembly=Project1.UI"
        Title="{DynamicResource Lang_Statistics}" Height="780" Width="1120"
                     MinWidth="980" MinHeight="700"
                     MaxWidth="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Width}"
                     MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height}"
                     WindowStartupLocation="CenterScreen" Icon="/20min20s;component/Resources/sunglasses.ico">
    <ui:Project1UIWindow.Resources>
        <SolidColorBrush x:Key="StatsPageBackgroundBrush" Color="#11111B"/>
        <SolidColorBrush x:Key="StatsShellBackgroundBrush" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="StatsShellBorderBrush" Color="#2A2C3B"/>
        <SolidColorBrush x:Key="StatsMutedBrush" Color="#A6ADC8"/>
        <SolidColorBrush x:Key="StatsTabsSurfaceBrush" Color="#181825"/>
        <SolidColorBrush x:Key="StatsTabsBorderBrush" Color="#313244"/>
        <SolidColorBrush x:Key="StatsContentSurfaceBrush" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="StatsContentBorderBrush" Color="#313244"/>
        <SolidColorBrush x:Key="StatsAccentBrush" Color="#CBA6F7"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD6F4"/>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Padding" Value="12,0,34,0"/>
            <Setter Property="Background" Value="#181825"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#181825"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#181825"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#313244"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#CDD6F4"/>
            </Style.Resources>
        </Style>
        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
            <Setter Property="Background" Value="#181825"/>
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#313244"/>
                    <Setter Property="Foreground" Value="#CDD6F4"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#313244"/>
                    <Setter Property="Foreground" Value="#CBA6F7"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#45475A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False"
                                                  IsTabStop="False"
                                                  Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Focusable="False"
                                           Background="Transparent">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Width="4"
                                                        CornerRadius="2"
                                                        Background="#45475A"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False"
                                                  IsTabStop="False"
                                                  Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="4"/>
                            </Trigger>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter Property="Width" Value="4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type ui:ContentCard}" BasedOn="{StaticResource {x:Type ui:ContentCard}}">
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        </Style>
        <Style x:Key="StatsSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="StatsSectionHintStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource StatsMutedBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
        </Style>
        <Style TargetType="TabControl" BasedOn="{StaticResource {x:Type TabControl}}">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}">
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style x:Key="TopNavTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}"
                                VerticalAlignment="Center"
                                SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="Header"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontSize="14"
                                              TextElement.FontWeight="SemiBold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#313244"/>
                                <Setter Property="Foreground" Value="#CDD6F4"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#313244"/>
                                <Setter Property="Foreground" Value="#CBA6F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TopNavTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="18"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Background="{StaticResource StatsTabsSurfaceBrush}"
                                    BorderBrush="{StaticResource StatsTabsBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="10">
                                <TabPanel x:Name="HeaderPanel"
                                          IsItemsHost="True"
                                          KeyboardNavigation.TabIndex="1"
                                          Margin="0"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Row="2"
                                    Background="{StaticResource StatsContentSurfaceBrush}"
                                    BorderBrush="{StaticResource StatsContentBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="24">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  ContentSource="SelectedContent"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Border" x:Key="DataCard">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,20,0,0"/>
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Grid>
                            <TextBlock Text="123"/>
                            <!--<ContentPresenter 
                                        
                                        x:Name="IconContent"
                                        Grid.Column="1"
                               
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                       HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />-->
                        </Grid>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <DropShadowEffect x:Key="CardShadow" BlurRadius="12" Direction="0" ShadowDepth="0" Opacity=".3" RenderingBias="Performance" ></DropShadowEffect>

            </Style.Resources>

            <Style.Triggers>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True" />
                    </MultiTrigger.Conditions>
                    <MultiTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Duration="0:0:0.15"
                    Storyboard.TargetProperty="Opacity" To="1" />
                            </Storyboard>
                        </BeginStoryboard>
                    </MultiTrigger.EnterActions>
                    <MultiTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard FillBehavior="Stop">
                                <ColorAnimation Duration="0:0:0.3"
                    Storyboard.TargetProperty="Background.Color" To="#008" />
                            </Storyboard>
                        </BeginStoryboard>
                    </MultiTrigger.ExitActions>
                </MultiTrigger>
            </Style.Triggers>
        </Style>
    </ui:Project1UIWindow.Resources>

    <ui:Project1UIWindow.ExtElement>
        <ui:Project1UIModal ClickClose="False" Duration="0" Show="{Binding Data.IsShowOnboarding,Mode=TwoWay}" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="9*"/>
                    <RowDefinition Height="1*"/>

                </Grid.RowDefinitions>
                <Border Margin="80,50" Background="#1E1E2E" BorderBrush="#313244" BorderThickness="1" CornerRadius="18" Opacity=".98">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="5" Opacity="0.3"  ShadowDepth="0"/>
                    </Border.Effect>
                    <ScrollViewer>
                        <StackPanel Margin="10" HorizontalAlignment="Center">
                            <Image Height="80" Source="/20min20s;component/Resources/ecology.png" Margin="0,20"/>
                            <TextBlock FontSize="24" Text="欢迎来到全新的数据统计页，看看有哪些改动吧！" HorizontalAlignment="Center"/>

                            <Grid Margin="0,20,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4*"/>
                                    <ColumnDefinition Width="6*"/>

                                </Grid.ColumnDefinitions>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock FontSize="18" Text="存储时间" FontWeight="Bold"/>
                                    <Image Height="80" Source="/20min20s;component/Resources/files_and_folder.png" Margin="0,20,0,0"/>
                                </StackPanel>
                                <TextBlock  VerticalAlignment="Center" Grid.Column="1" FontSize="14" Text="从现在开始将不限制数据保留天数，您的数据将永久保存在本地。" TextWrapping="WrapWithOverflow"/>
                            </Grid>

                            <Grid Margin="0,20,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="6*"/>
                                    <ColumnDefinition Width="4*"/>

                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock FontSize="18" Text="全新的UI" FontWeight="Bold"/>
                                    <Image Height="80" Source="/20min20s;component/Resources/creative_process_.png" Margin="0,20,0,0"/>
                                </StackPanel>
                                <TextBlock  VerticalAlignment="Center" Grid.Column="0" FontSize="14" Text="不仅重新设计了图表的UI视觉，还加入了图表动效，让数据不那么冰冷单调。" TextWrapping="WrapWithOverflow"/>
                            </Grid>
                            <Grid Margin="0,20,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4*"/>
                                    <ColumnDefinition Width="6*"/>

                                </Grid.ColumnDefinitions>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock FontSize="18" Text="数据分析" FontWeight="Bold"/>
                                    <Image Height="80" Source="/20min20s;component/Resources/product_manager.png" Margin="0,20,0,0"/>
                                </StackPanel>
                                <TextBlock  VerticalAlignment="Center" Grid.Column="1" FontSize="14" Text="20min20s 不仅会单独对工作时间、休息时间、跳过次数做出分析，还会结合您的设置以及一周的工作时间给您提供参考建议。" TextWrapping="WrapWithOverflow"/>
                            </Grid>


                        </StackPanel>
                    </ScrollViewer>
                </Border>
                <ui:Project1UIButton Grid.Row="1" Content="了 解" FontSize="16" Width="160" Height="35" Command="{Binding CloseOnboardingCommand}"/>
            </Grid>
        </ui:Project1UIModal>
    </ui:Project1UIWindow.ExtElement>
    <Grid Background="{StaticResource StatsPageBackgroundBrush}">
        <Border Margin="20"
                Background="{StaticResource StatsShellBackgroundBrush}"
                BorderBrush="{StaticResource StatsShellBorderBrush}"
                BorderThickness="1"
                CornerRadius="22">
            <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="4,4,4,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{DynamicResource Lang_Statistics}" FontSize="22" FontWeight="SemiBold"/>
                <TextBlock Text="{DynamicResource Lang_Statisticsanalysis}" Margin="0,6,0,0" Foreground="{StaticResource StatsMutedBrush}"/>
            </StackPanel>
            <Border Grid.Column="1"
                    Padding="12,8"
                    Background="#313244"
                    BorderBrush="#45475A"
                    BorderThickness="1"
                    CornerRadius="12"
                    VerticalAlignment="Center">
                <TextBlock Text="20min20s" Foreground="#CDD6F4" FontWeight="SemiBold"/>
            </Border>
        </Grid>
    <Grid Grid.Row="1" Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="9*"/>
            <RowDefinition Height="auto"/>

        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Style="{StaticResource TopNavTabControlStyle}" ItemContainerStyle="{StaticResource TopNavTabItemStyle}">
            <TabItem>
                <TabItem.Header>
                    <TextBlock>
                        <Run FontFamily="Segoe MDL2 Assets" Text="&#xE787;"/>
                        <Run Text="  "/>
                        <Run Text="{DynamicResource Lang_Thisweek}"/>
                    </TextBlock>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Margin="0,0,0,18">
                        <TextBlock Text="{DynamicResource Lang_Thisweek}" Style="{StaticResource StatsSectionTitleStyle}"/>
                        <TextBlock Text="查看本周工作、休息和跳过情况，并结合趋势给出简短分析。"
                                   Style="{StaticResource StatsSectionHintStyle}"/>
                    </StackPanel>
                    <Grid Grid.Row="1">
                        <ScrollViewer>
                            <StackPanel >
                                <!--工作-->
                                <ui:ContentCard Padding="30"  Margin="0" Background="#23263A" BorderBrush="#313244" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>

                                        </Grid.ColumnDefinitions>
                                        <Grid Width="350" HorizontalAlignment="Left">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="230"/>
                                            </Grid.RowDefinitions>
                                            <!--工作-->
                                            <StackPanel Grid.Row="0"  VerticalAlignment="Bottom" >
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                                    <Image Source="/Resources/work.png" Width="32" Height="32"/>

                                                    <!--<ui:Icon Unicode="&#xE977;" FontSize="24" VerticalAlignment="Center" Foreground="{DynamicResource ThemeBrush}"/>-->
                                                    <TextBlock Text="{DynamicResource Lang_Work}" FontSize="17" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#89B4FA"/>
                                                </StackPanel>
                                                <Grid Margin="0,20,0,0">
                                                    <ui:CompareView DataA="{Binding Data.LastWeekWork}" DataB="{Binding Data.WeekWork}" PopupText="{DynamicResource Lang_StatisticsWeekHoursTip}"/>
                                                </Grid>
                                            </StackPanel>
                                            <chart:Chart Grid.Row="1" Data="{Binding Data.WeekWorkData}" TickText="{DynamicResource Lang_StatisticsXhours}" TickLabelWidth="70" Margin="0,10,0,0" ItemColor="#89B4FA" Background="Transparent" AverageDivisor="{Binding Data.WeekTrueWorkDays}" IsAnimation="{Binding Data.IsAnimation}"/>

                                        </Grid>
                                        <Grid Grid.Column="1" Margin="0,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center">

                                            <StackPanel>
                                                <Image MaxWidth="300" Source="{Binding Data.WorktimeImageSource}"  HorizontalAlignment="Center"/>
                                                <ContentControl>
                                                    <ContentControl.ContentTemplate>
                                                        <DataTemplate>
                                                            <Border x:Name="WorkLevelBorder" Width="auto" HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center"
                                                        CornerRadius="5" DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window, AncestorLevel=1}, Path=DataContext}">


                                                                <StackPanel Orientation="Horizontal" Margin="10,5" VerticalAlignment="Center">

                                                                    <ui:Icon x:Name="WorkLevelIcon" Unicode="&#xE74B;" VerticalAlignment="Center" VerticalContentAlignment="Center" Foreground="{Binding ElementName=WeekWorkLevelText,Path=Foreground}"/>
                                                                    <TextBlock x:Name="WeekWorkLevelText" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Data.WorkAnalysis}" TextWrapping="WrapWithOverflow" FontSize="14" Margin="5,0,0,0"/>
                                                                    <TextBlock x:Name="WeekWorkLevel" Visibility="Collapsed" Text="{Binding Data.WeekWorkLevel}"/>
                                                                </StackPanel>

                                                            </Border>
                                                            <DataTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding ElementName=WeekWorkLevel,Path=Text}" Value="0">
                                                                    <Setter TargetName="WorkLevelBorder" Property="Background" Value="#313244"/>
                                                                    <Setter TargetName="WeekWorkLevelText" Property="Foreground" Value="#CDD6F4"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ElementName=WeekWorkLevel,Path=Text}" Value="1">
                                                                    <Setter TargetName="WorkLevelBorder" Property="Background" Value="#4C3A32"/>
                                                                    <Setter TargetName="WeekWorkLevelText" Property="Foreground" Value="#FAB387"/>
                                                                    <Setter TargetName="WorkLevelIcon" Property="Unicode" Value="&#xE74A;"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ElementName=WeekWorkLevel,Path=Text}" Value="2">
                                                                    <Setter TargetName="WorkLevelBorder" Property="Background" Value="#4B3140"/>
                                                                    <Setter TargetName="WeekWorkLevelText" Property="Foreground" Value="#F38BA8"/>
                                                                    <Setter TargetName="WorkLevelIcon" Property="Unicode" Value="&#xE8C9;"/>
                                                                </DataTrigger>
                                                            </DataTemplate.Triggers>
                                                        </DataTemplate>
                                                    </ContentControl.ContentTemplate>
                                                </ContentControl>
                                            </StackPanel>


                                        </Grid>
                                    </Grid>

                                </ui:ContentCard>
                                <!--休息-->
                                <ui:ContentCard Padding="30" Background="#1D2A26" BorderBrush="#294036" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>

                                        </Grid.ColumnDefinitions>
                                        <Grid Width="350" HorizontalAlignment="Left">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="230"/>
                                            </Grid.RowDefinitions>
                                            <!--休息-->
                                            <StackPanel Grid.Row="0"  VerticalAlignment="Bottom" >
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="/Resources/rest.png" Width="32" Height="32"/>
                                                    <!--<ui:Icon Unicode="&#xF2FA;" FontSize="24" VerticalAlignment="Center" Foreground="#82D29A"/>-->
                                                    <TextBlock Text="{DynamicResource Lang_Break}" FontSize="17" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#A6E3A1"/>
                                                </StackPanel>
                                                <Grid Margin="0,20,0,0">
                                                    <ui:CompareView DataA="{Binding Data.LastWeekRest}" DataB="{Binding Data.WeekRest}" PopupText="{DynamicResource Lang_StatisticsWeekMinutesTip}"/>
                                                </Grid>
                                            </StackPanel>
                                            <chart:Chart Grid.Row="1" Data="{Binding Data.WeekRestData}" TickText="{DynamicResource Lang_StatisticsXminutes}" TickLabelWidth="70" ItemColor="#A6E3A1" Background="Transparent" AverageDivisor="{Binding Data.WeekTrueWorkDays}" IsAnimation="{Binding Data.IsAnimation}"/>

                                        </Grid>
                                        <Grid Grid.Column="1" Margin="0,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <StackPanel>
                                                <Image MaxWidth="300" Source="{Binding Data.ResttimeImageSource}" />
                                                <ContentControl>
                                                    <ContentControl.ContentTemplate>
                                                        <DataTemplate>
                                                            <Border x:Name="RestLevelBorder" Width="auto" HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center"
                                                        CornerRadius="5" DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window, AncestorLevel=1}, Path=DataContext}">


                                                                <StackPanel Orientation="Horizontal" Margin="10,5" VerticalAlignment="Center">

                                                                    <ui:Icon x:Name="RestLevelIcon" Unicode="&#xE74B;" VerticalAlignment="Center" VerticalContentAlignment="Center" Foreground="{Binding ElementName=WeekRestLevelText,Path=Foreground}"/>
                                                                    <TextBlock x:Name="WeekRestLevelText" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Data.RestAnalysis}" TextWrapping="WrapWithOverflow" FontSize="14" Margin="5,0,0,0"/>
                                                                    <TextBlock x:Name="WeekRestLevel" Visibility="Collapsed" Text="{Binding Data.WeekRestLevel}"/>
                                                                </StackPanel>

                                                            </Border>
                                                            <DataTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding ElementName=WeekRestLevel,Path=Text}" Value="0">
                                                                    <Setter TargetName="RestLevelBorder" Property="Background" Value="#313244"/>
                                                                    <Setter TargetName="WeekRestLevelText" Property="Foreground" Value="#CDD6F4"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ElementName=WeekRestLevel,Path=Text}" Value="1">
                                                                    <Setter TargetName="RestLevelBorder" Property="Background" Value="#4C3A32"/>
                                                                    <Setter TargetName="WeekRestLevelText" Property="Foreground" Value="#FAB387"/>
                                                                    <Setter TargetName="RestLevelIcon" Property="Unicode" Value="&#xE74A;"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ElementName=WeekRestLevel,Path=Text}" Value="2">
                                                                    <Setter TargetName="RestLevelBorder" Property="Background" Value="#4B3140"/>
                                                                    <Setter TargetName="WeekRestLevelText" Property="Foreground" Value="#F38BA8"/>
                                                                    <Setter TargetName="RestLevelIcon" Property="Unicode" Value="&#xE8C9;"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ElementName=WeekRestLevel,Path=Text}" Value="3">
                                                                    <Setter TargetName="RestLevelBorder" Property="Background" Value="#294036"/>
                                                                    <Setter TargetName="WeekRestLevelText" Property="Foreground" Value="#A6E3A1"/>
                                                                    <Setter TargetName="RestLevelIcon" Property="Unicode" Value="&#xE8E1;"/>
                                                                </DataTrigger>
                                                            </DataTemplate.Triggers>
                                                        </DataTemplate>
                                                    </ContentControl.ContentTemplate>
                                                </ContentControl>

                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </ui:ContentCard>
                                <!--跳过-->
                                <ui:ContentCard Padding="30" Margin="0,0,0,0" Background="#32232D" BorderBrush="#4B3140" BorderThickness="1">

                                    <Grid >
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>

                                        </Grid.ColumnDefinitions>

                                        <Grid Width="350" HorizontalAlignment="Left" >
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="230"/>
                                            </Grid.RowDefinitions>
                                            <!--跳过-->
                                            <StackPanel Grid.Row="0"  VerticalAlignment="Bottom" >
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="/Resources/break.png" Width="32" Height="32"/>

                                                    <!--<ui:Icon Unicode="&#xEE6E;" FontSize="24" VerticalAlignment="Center" Foreground="#F94520"/>-->
                                                    <TextBlock Text="{DynamicResource Lang_Skip}" FontSize="17" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#F38BA8"/>
                                                </StackPanel>
                                                <Grid Margin="0,20,0,0">
                                                    <ui:CompareView DataA="{Binding Data.LastWeekSkip}" DataB="{Binding Data.WeekSkip}" PopupText="{DynamicResource Lang_StatisticsWeekXTip}"/>
                                                </Grid>
                                            </StackPanel>
                                            <chart:Chart Grid.Row="1" Data="{Binding Data.WeekSkipData}" TickText="{DynamicResource Lang_StatisticsX}" TickLabelWidth="70" ItemColor="#F38BA8" Background="Transparent" AverageDivisor="{Binding Data.WeekTrueWorkDays}" IsAnimation="{Binding Data.IsAnimation}"/>

                                        </Grid>
                                        <Grid Grid.Column="1" Margin="0,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <StackPanel>
                                                <Image MaxWidth="300" Source="{Binding Data.SkipImageSource}" />
                                                <ContentControl>
                                                    <ContentControl.ContentTemplate>
                                                        <DataTemplate>
                                                            <Border x:Name="SkipLevelBorder" Width="auto" HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center"
                                                        CornerRadius="5" DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window, AncestorLevel=1}, Path=DataContext}">


                                                                <StackPanel Orientation="Horizontal" Margin="10,5" VerticalAlignment="Center">

                                                                    <ui:Icon x:Name="SkipLevelIcon" Unicode="&#xE74B;" VerticalAlignment="Center" VerticalContentAlignment="Center" Foreground="{Binding ElementName=WeekSkipLevelText,Path=Foreground}"/>
                                                                    <TextBlock x:Name="WeekSkipLevelText" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Data.SkipAnalysis}" TextWrapping="WrapWithOverflow" FontSize="14" Margin="5,0,0,0"/>
                                                                    <TextBlock x:Name="WeekSkipLevel" Visibility="Collapsed" Text="{Binding Data.WeekSkipLevel}"/>
                                                                </StackPanel>

                                                            </Border>
                                                            <DataTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding ElementName=WeekSkipLevel,Path=Text}" Value="0">
                                                                    <Setter TargetName="SkipLevelBorder" Property="Background" Value="#313244"/>
                                                                    <Setter TargetName="WeekSkipLevelText" Property="Foreground" Value="#CDD6F4"/>
                                                                </DataTrigger>

                                                                <DataTrigger Binding="{Binding ElementName=WeekSkipLevel,Path=Text}" Value="1">
                                                                    <Setter TargetName="SkipLevelBorder" Property="Background" Value="#4B3140"/>
                                                                    <Setter TargetName="WeekSkipLevelText" Property="Foreground" Value="#F38BA8"/>
                                                                    <Setter TargetName="SkipLevelIcon" Property="Unicode" Value="&#xE8C9;"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ElementName=WeekSkipLevel,Path=Text}" Value="2">
                                                                    <Setter TargetName="SkipLevelBorder" Property="Background" Value="#294036"/>
                                                                    <Setter TargetName="WeekSkipLevelText" Property="Foreground" Value="#A6E3A1"/>
                                                                    <Setter TargetName="SkipLevelIcon" Property="Unicode" Value="&#xE8E1;"/>
                                                                </DataTrigger>
                                                            </DataTemplate.Triggers>
                                                        </DataTemplate>
                                                    </ContentControl.ContentTemplate>
                                                </ContentControl>
                                            </StackPanel>

                                        </Grid>
                                    </Grid>

                                </ui:ContentCard>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>

            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <TextBlock>
                        <Run FontFamily="Segoe MDL2 Assets" Text="&#xE823;"/>
                        <Run Text="  "/>
                        <Run Text="{DynamicResource Lang_Monthlyview}"/>
                    </TextBlock>
                </TabItem.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="25*"/>
                        <ColumnDefinition Width="741*"/>
                    </Grid.ColumnDefinitions>
                    <!--<Grid.Background>
                        <ImageBrush ImageSource="/20min20s;component/Resources/conference_presentation__monochromatic.png" Stretch="Uniform" Opacity=".02"/>
                    </Grid.Background>-->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,4">
                        <TextBlock Text="{DynamicResource Lang_Monthlyview}" Style="{StaticResource StatsSectionTitleStyle}"/>
                        <TextBlock Text="按月份回看累计工作、休息、跳过和番茄时钟数据，支持导出当月记录。"
                                   Style="{StaticResource StatsSectionHintStyle}"/>
                    </StackPanel>
                    <Grid Grid.Row="1" VerticalAlignment="Top" Grid.ColumnSpan="2" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!--<TextBlock Text="{DynamicResource Lang_Monthly}" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>-->
                        <date:DatePicker SelectedYear="{Binding Data.Year,Mode=TwoWay}" SelectedMonth="{Binding Data.Month,Mode=TwoWay}" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                        <ui:Project1UIButton 
            Command="{Binding exportDataCommand}"
            Content="{DynamicResource Lang_ExportMonthData}"
                            Icon="Export"
                            Padding="10,6"
                            Grid.Column="1"
                            Margin="0,0,10,0"
                Width="auto"
                            HorizontalAlignment="Right"
                Height="auto"
                Style="{DynamicResource basic}"
                Background="#313244"
                Foreground="#CDD6F4"
                BorderBrush="#45475A"/>
                    </Grid>
                    <ScrollViewer Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,0">
                        <StackPanel Margin="8,12,8,8">
                            <ui:ContentCard Padding="24" Background="#23263A" BorderBrush="#313244" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Image Source="/Resources/work.png" Width="32" Height="32"/>
                                        <TextBlock Text="{DynamicResource Lang_Work}" FontSize="17" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#89B4FA"/>
                                    </StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <ui:CompareView DataA="{Binding Data.LastMonthWork}" DataB="{Binding Data.MonthWork}" PopupText="{DynamicResource Lang_StatisticsMonthlyHoursTip}"/>
                                    </Grid>
                                    <chart:Chart Data="{Binding Data.MonthWorkData}" TickText="{DynamicResource Lang_StatisticsXhours}" TickLabelWidth="70" Margin="0,6,0,0" ItemColor="#89B4FA" Background="Transparent" IsAnimation="{Binding Data.IsAnimation}">
                                        <chart:Chart.ContextMenu>
                                            <ContextMenu StaysOpen="true">
                                                <MenuItem Header="生成图片" Command="{Binding GenerateMonthlyDataImgCommand}"/>
                                            </ContextMenu>
                                        </chart:Chart.ContextMenu>
                                    </chart:Chart>
                                </StackPanel>
                            </ui:ContentCard>

                            <ui:ContentCard Padding="24" Background="#1D2A26" BorderBrush="#294036" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Image Source="/Resources/rest.png" Width="32" Height="32"/>
                                        <TextBlock Text="{DynamicResource Lang_Break}" FontSize="17" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#A6E3A1"/>
                                    </StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <ui:CompareView DataA="{Binding Data.LastMonthRest}" DataB="{Binding Data.MonthRest}" PopupText="{DynamicResource Lang_StatisticsMonthlyMinutesTip}"/>
                                    </Grid>
                                    <chart:Chart Data="{Binding Data.MonthRestData}" TickText="{DynamicResource Lang_StatisticsXminutes}" TickLabelWidth="70" ItemColor="#A6E3A1" Background="Transparent" IsAnimation="{Binding Data.IsAnimation}"/>
                                </StackPanel>
                            </ui:ContentCard>

                            <ui:ContentCard Padding="24" Background="#32232D" BorderBrush="#4B3140" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Image Source="/Resources/break.png" Width="32" Height="32"/>
                                        <TextBlock Text="{DynamicResource Lang_Skip}" FontSize="17" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#F38BA8"/>
                                    </StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <ui:CompareView DataA="{Binding Data.LastMonthSkip}" DataB="{Binding Data.MonthSkip}" PopupText="{DynamicResource Lang_StatisticsMonthlyXTip}"/>
                                    </Grid>
                                    <chart:Chart Data="{Binding Data.MonthSkipData}" TickText="{DynamicResource Lang_StatisticsX}" TickLabelWidth="70" ItemColor="#F38BA8" Background="Transparent" IsAnimation="{Binding Data.IsAnimation}"/>
                                </StackPanel>
                            </ui:ContentCard>

                            <ui:ContentCard Padding="24" Margin="0,0,0,0" Background="#33251F" BorderBrush="#4C3A32" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Image Source="/Resources/tomato.png" Width="32" Height="32"/>
                                        <TextBlock Text="{DynamicResource Lang_Tomato}" FontSize="17" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#FAB387"/>
                                    </StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <ui:CompareView DataA="{Binding Data.LastMonthTomato}" DataB="{Binding Data.MonthTomato}" PopupText="{DynamicResource Lang_StatisticsMonthlyNumberTip}"/>
                                    </Grid>
                                    <chart:Chart Data="{Binding Data.MonthTomatoData}" TickText="{DynamicResource Lang_number}" TickLabelWidth="70" ItemColor="#FAB387" Background="Transparent" IsAnimation="{Binding Data.IsAnimation}"/>
                                </StackPanel>
                            </ui:ContentCard>
                        </StackPanel>
                    </ScrollViewer>

                </Grid>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <TextBlock>
                        <Run FontFamily="Segoe MDL2 Assets" Text="&#xE81E;"/>
                        <Run Text="  "/>
                        <Run Text="{DynamicResource Lang_TomatoTimer}"/>
                    </TextBlock>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Margin="0,0,0,18">
                        <TextBlock Text="{DynamicResource Lang_TomatoTimer}" Style="{StaticResource StatsSectionTitleStyle}"/>
                        <TextBlock Text="查看番茄时钟完成数和近期专注节奏，用更轻的视图展示累计情况。"
                                   Style="{StaticResource StatsSectionHintStyle}"/>
                    </StackPanel>
                    <Grid Grid.Row="1">
                        <ScrollViewer>
                            <StackPanel >

                                <!--获得番茄-->
                                <Border Padding="20" CornerRadius="18" Margin="0,0,0,0" BorderBrush="#4C3A32" BorderThickness="1">
                                    <Border.Background>
                                        <SolidColorBrush Color="#33251F" Opacity=".98"/>
                                    </Border.Background>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>

                                        </Grid.ColumnDefinitions>
                                        <Grid Width="350" HorizontalAlignment="Left">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="230"/>
                                            </Grid.RowDefinitions>
                                            <!--tomato-->
                                            <StackPanel Grid.Row="0"  VerticalAlignment="Bottom" >
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="/Resources/tomato.png" Width="32" Height="32"/>

                                                    <!--<Image Source="/ProjectEye;component/Resources/tomato.ico" Width="22"/>-->
                                                    <TextBlock Text="{DynamicResource Lang_Tomato}" FontSize="17" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#FAB387"/>
                                                </StackPanel>
                                                <Grid Margin="0,20,0,0">
                                                    <ui:CompareView DataA="{Binding Data.TomatoLastWeekCount}" DataB="{Binding Data.TomatoWeekCount}" PopupText="{DynamicResource Lang_StatisticsWeekXTip}"/>
                                                </Grid>
                                            </StackPanel>
                                            <chart:Chart Grid.Row="1" Data="{Binding Data.TomatoWeekData}" TickText=" {value}" TickLabelWidth="70" ItemColor="#FAB387" Background="Transparent" AverageDivisor="{Binding Data.WeekTrueWorkDays}" IsAnimation="{Binding Data.IsAnimation}"/>

                                        </Grid>
                                        <Grid Grid.Column="1" Margin="0,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <StackPanel>
                                                <Image Width="150" Height="150" Source="/20min20s;component/Resources/growth_monochromatic.png" />
                                                <TextBlock Text="{DynamicResource Lang_Tomatodescription}" TextWrapping="WrapWithOverflow" Margin="0,20,0,0" FontSize="16"/>
                                            </StackPanel>

                                        </Grid>
                                    </Grid>
                                </Border>

                                <TextBlock Text="{DynamicResource Lang_Tomatodescription2}" TextWrapping="Wrap" Margin="0,20,0,0" />
                                <Button Style="{DynamicResource CustomButton}" Command="{Binding openURLCommand}" CommandParameter="https://zh.wikipedia.org/wiki/%E7%95%AA%E8%8C%84%E5%B7%A5%E4%BD%9C%E6%B3%95" HorizontalAlignment="Left">
                                    
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,0" Cursor="Hand">
                                                <ui:Icon Unicode="&#xE72A;" Foreground="#CBA6F7"/>
                                                <TextBlock Text="{DynamicResource Lang_Learnmore}" Padding="10" Foreground="#CBA6F7"/>
                                            </StackPanel>
                                     
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>

            </TabItem>
        </TabControl>
    </Grid>
            </Grid>
        </Border>
    </Grid>
</ui:Project1UIWindow>
